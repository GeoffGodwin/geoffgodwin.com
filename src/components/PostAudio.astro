---
/**
 * PostAudio — Narration player for blog posts.
 * Sits below the post header. Supports seeking, playback speed,
 * and a download link for offline listening.
 */
interface Props {
  src: string;
  title: string;
}

const { src, title } = Astro.props;
---

<div
  id="post-audio-player"
  class="post-audio-wrap"
  aria-label="Listen to this post"
>
  <!-- Row 1: controls -->
  <div class="post-audio-controls">
    <!-- Play/pause -->
    <button
      id="post-audio-btn"
      class="post-audio-btn"
      aria-label="Play narration"
      type="button"
    >
      <svg
        id="post-audio-icon-play"
        class="post-audio-icon"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M3 2.5a.5.5 0 0 1 .765-.424l10 5.5a.5.5 0 0 1 0 .848l-10 5.5A.5.5 0 0 1 3 13.5v-11z"></path>
      </svg>
      <svg
        id="post-audio-icon-pause"
        class="post-audio-icon post-audio-hidden"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5zm5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5z"></path>
      </svg>
    </button>

    <!-- Time -->
    <span class="post-audio-time" id="post-audio-time">
      <span id="post-audio-current">0:00</span>
      <span class="opacity-30">/</span>
      <span id="post-audio-duration" class="opacity-50">-:--</span>
    </span>

    <!-- Progress bar (seekable) -->
    <div
      class="post-audio-track"
      id="post-audio-track"
      role="slider"
      aria-label="Seek audio"
      aria-valuenow={0}
      aria-valuemin={0}
      aria-valuemax={100}
      tabindex="0"
    >
      <div class="post-audio-track-fill" id="post-audio-track-fill"></div>
    </div>

    <!-- Speed toggle -->
    <button
      id="post-audio-speed"
      class="post-audio-speed"
      aria-label="Playback speed"
      type="button"
    >1x</button>

    <!-- Download -->
    <a
      href={src}
      download
      class="post-audio-download"
      aria-label={`Download narration of ${title}`}
      title="Download MP3"
    >
      <svg class="post-audio-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
    </a>
  </div>

  <!-- Label row -->
  <div class="post-audio-label">
    <span class="post-audio-prefix" aria-hidden="true">&#9654;</span>
    <span>Listen to this post</span>
  </div>

  <!-- Hidden audio element -->
  <audio id="post-audio-el" preload="metadata" aria-hidden="true">
    <source src={src} type="audio/mpeg" />
    Your browser does not support the audio element.
  </audio>
</div>

<!--
  Sticky mini-player. Same single <audio id="post-audio-el"> drives both UIs.
  Hidden until the user has interacted with the inline player AND scrolled it
  out of view. Dismissible per page-load.
-->
<div
  id="post-audio-mini"
  class="post-audio-mini"
  data-visible="false"
  aria-hidden="true"
  aria-label="Listen to this post (mini player)"
>
  <div class="post-audio-mini-inner">
    <!-- Play/pause -->
    <button
      id="post-audio-mini-btn"
      class="post-audio-btn post-audio-mini-btn"
      aria-label="Play narration"
      type="button"
    >
      <svg
        id="post-audio-mini-icon-play"
        class="post-audio-icon"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M3 2.5a.5.5 0 0 1 .765-.424l10 5.5a.5.5 0 0 1 0 .848l-10 5.5A.5.5 0 0 1 3 13.5v-11z"></path>
      </svg>
      <svg
        id="post-audio-mini-icon-pause"
        class="post-audio-icon post-audio-hidden"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5zm5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5z"></path>
      </svg>
    </button>

    <!-- Time -->
    <span class="post-audio-time post-audio-mini-time">
      <span id="post-audio-mini-current">0:00</span>
      <span class="opacity-30">/</span>
      <span id="post-audio-mini-duration" class="opacity-50">-:--</span>
    </span>

    <!-- Progress bar (desktop only — hidden on mobile via CSS) -->
    <div
      class="post-audio-track post-audio-mini-track"
      id="post-audio-mini-track"
      role="slider"
      aria-label="Seek audio"
      aria-valuenow={0}
      aria-valuemin={0}
      aria-valuemax={100}
      tabindex="0"
    >
      <div class="post-audio-track-fill" id="post-audio-mini-track-fill"></div>
    </div>

    <!-- Jump back to inline player -->
    <button
      id="post-audio-mini-jump"
      class="post-audio-mini-iconbtn"
      aria-label="Scroll back to player"
      title="Scroll to player"
      type="button"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
        <circle cx="12" cy="12" r="2.5" fill="currentColor"></circle>
        <line x1="12" y1="2" x2="12" y2="5"></line>
        <line x1="12" y1="19" x2="12" y2="22"></line>
        <line x1="2" y1="12" x2="5" y2="12"></line>
        <line x1="19" y1="12" x2="22" y2="12"></line>
      </svg>
    </button>

    <!-- Dismiss (per page-load) -->
    <button
      id="post-audio-mini-close"
      class="post-audio-mini-iconbtn"
      aria-label="Hide mini player"
      title="Hide mini player"
      type="button"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>
  </div>
</div>

<style>
  .post-audio-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in oklab, var(--border) 30%, transparent);
    background: color-mix(in oklab, var(--muted) 8%, transparent);
    backdrop-filter: blur(6px);
    font-family: var(--font-cartograph, monospace);
    font-size: 0.75rem;
    color: var(--foreground);
    transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
    max-width: 100%;
  }

  .post-audio-wrap.playing {
    border-color: color-mix(in oklab, var(--accent) 45%, transparent);
    background: color-mix(in oklab, var(--accent) 5%, transparent);
    box-shadow: 0 0 20px -6px color-mix(in oklab, var(--accent) 15%, transparent);
  }

  .post-audio-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Play/pause button */
  .post-audio-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--accent) 50%, transparent);
    background: color-mix(in oklab, var(--accent) 12%, transparent);
    color: var(--accent);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }

  .post-audio-btn:hover {
    background: color-mix(in oklab, var(--accent) 22%, transparent);
    border-color: var(--accent);
    transform: scale(1.08);
  }

  .post-audio-btn:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
  }

  .post-audio-icon {
    width: 0.8rem;
    height: 0.8rem;
  }

  .post-audio-hidden {
    display: none !important;
  }

  /* Time display */
  .post-audio-time {
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* Seekable track */
  .post-audio-track {
    flex: 1;
    height: 6px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--border) 30%, transparent);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    min-width: 3rem;
  }

  .post-audio-track:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
  }

  .post-audio-track-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: var(--accent);
    transition: width 0.1s linear;
    pointer-events: none;
  }

  /* Speed button */
  .post-audio-speed {
    flex-shrink: 0;
    padding: 0.15rem 0.45rem;
    border-radius: 0.4rem;
    border: 1px solid color-mix(in oklab, var(--border) 35%, transparent);
    background: color-mix(in oklab, var(--muted) 12%, transparent);
    color: var(--foreground);
    opacity: 0.7;
    font-family: var(--font-cartograph, monospace);
    font-size: 0.65rem;
    cursor: pointer;
    transition: opacity 0.2s, border-color 0.2s;
  }

  .post-audio-speed:hover {
    opacity: 1;
    border-color: color-mix(in oklab, var(--accent) 50%, transparent);
  }

  .post-audio-speed:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
  }

  /* Download link */
  .post-audio-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--foreground);
    opacity: 0.45;
    transition: opacity 0.2s, color 0.2s;
    background: none !important;
  }

  .post-audio-download:hover {
    opacity: 1;
    color: var(--accent);
  }

  .post-audio-download:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
  }

  /* Label */
  .post-audio-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.45;
    user-select: none;
  }

  .post-audio-prefix {
    font-size: 0.55rem;
    color: var(--accent);
  }

  /* ───────── Sticky mini-player ───────── */
  .post-audio-mini {
    position: fixed;
    left: 0;
    right: 0;
    top: var(--header-height, 64px);
    z-index: 30; /* under header (z-40) so header still owns the very top edge */
    background: color-mix(in srgb, var(--background) 80%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 30%, transparent);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    box-shadow: 0 4px 18px -10px color-mix(in oklab, var(--foreground) 25%, transparent);
    font-family: var(--font-cartograph, monospace);
    font-size: 0.75rem;
    color: var(--foreground);
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms ease-out,
      top 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-audio-mini[data-visible="true"] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .post-audio-mini-inner {
    max-width: 42rem; /* matches inline player's max-w-2xl wrapper for visual continuity */
    margin: 0 auto;
    padding: 0.45rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Slightly smaller round button to match slim bar height */
  .post-audio-mini-btn {
    width: 1.85rem;
    height: 1.85rem;
  }

  .post-audio-mini-time {
    font-size: 0.72rem;
  }

  .post-audio-mini-track {
    flex: 1;
  }

  .post-audio-mini-iconbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
    border: none;
    background: transparent;
    color: var(--foreground);
    opacity: 0.45;
    border-radius: 0.4rem;
    cursor: pointer;
    transition: opacity 0.2s, color 0.2s, background 0.2s;
  }

  .post-audio-mini-iconbtn svg {
    width: 0.95rem;
    height: 0.95rem;
  }

  .post-audio-mini-iconbtn:hover {
    opacity: 1;
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 8%, transparent);
  }

  .post-audio-mini-iconbtn:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
    opacity: 1;
  }

  /* Mobile: dock to bottom, drop progress + jump button, keep play/time/close */
  @media (max-width: 639px) {
    .post-audio-mini {
      top: auto;
      bottom: 0;
      border-bottom: none;
      border-top: 1px solid color-mix(in oklab, var(--border) 30%, transparent);
      box-shadow: 0 -4px 18px -10px color-mix(in oklab, var(--foreground) 25%, transparent);
      transform: translateY(100%);
      padding-bottom: env(safe-area-inset-bottom);
    }

    .post-audio-mini-inner {
      padding: 0.55rem 0.85rem;
      gap: 0.5rem;
    }

    .post-audio-mini-track,
    #post-audio-mini-jump {
      display: none;
    }

    /* Push time to the left side, close button stays on the right */
    .post-audio-mini-time {
      flex: 1;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function initPostAudio() {
    const audio = document.getElementById("post-audio-el");
    const btn = document.getElementById("post-audio-btn");
    const iconPlay = document.getElementById("post-audio-icon-play");
    const iconPause = document.getElementById("post-audio-icon-pause");
    const currentEl = document.getElementById("post-audio-current");
    const durationEl = document.getElementById("post-audio-duration");
    const track = document.getElementById("post-audio-track");
    const fill = document.getElementById("post-audio-track-fill");
    const speedBtn = document.getElementById("post-audio-speed");
    const wrap = document.getElementById("post-audio-player");

    // Mini-player elements
    const mini = document.getElementById("post-audio-mini");
    const miniBtn = document.getElementById("post-audio-mini-btn");
    const miniIconPlay = document.getElementById("post-audio-mini-icon-play");
    const miniIconPause = document.getElementById("post-audio-mini-icon-pause");
    const miniCurrent = document.getElementById("post-audio-mini-current");
    const miniDuration = document.getElementById("post-audio-mini-duration");
    const miniTrack = document.getElementById("post-audio-mini-track");
    const miniFill = document.getElementById("post-audio-mini-track-fill");
    const miniClose = document.getElementById("post-audio-mini-close");
    const miniJump = document.getElementById("post-audio-mini-jump");

    if (!audio || !btn) return;

    const speeds = [1, 1.25, 1.5, 1.75, 2];
    let speedIdx = 0;

    // Mini visibility: shown only after user has interacted with the inline player
    // AND inline is scrolled out from under the header. Dismissible per page-load.
    // All three flags reset on page navigation because data-astro-rerun re-runs this IIFE.
    let hasInteracted = false;
    let dismissed = false;
    let inlineVisible = true;

    function updateMiniVisibility() {
      const show = hasInteracted && !dismissed && !inlineVisible;
      if (mini) {
        mini.dataset.visible = show ? "true" : "false";
        mini.setAttribute("aria-hidden", show ? "false" : "true");
      }
      // Body-level flag so unrelated components (e.g. BackToTop) can react without
      // direct coupling to the audio player.
      document.body.dataset.audioMiniVisible = show ? "true" : "false";
    }

    function markInteracted() {
      if (hasInteracted) return;
      hasInteracted = true;
      updateMiniVisibility();
    }

    function fmt(s) {
      if (!isFinite(s)) return "-:--";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ":" + String(sec).padStart(2, "0");
    }

    function syncUI() {
      const paused = audio.paused;
      iconPlay.classList.toggle("post-audio-hidden", !paused);
      iconPause.classList.toggle("post-audio-hidden", paused);
      btn.setAttribute("aria-label", paused ? "Play narration" : "Pause narration");
      if (wrap) wrap.classList.toggle("playing", !paused);

      if (miniIconPlay) miniIconPlay.classList.toggle("post-audio-hidden", !paused);
      if (miniIconPause) miniIconPause.classList.toggle("post-audio-hidden", paused);
      if (miniBtn) miniBtn.setAttribute("aria-label", paused ? "Play narration" : "Pause narration");
    }

    function togglePlay() {
      if (audio.paused) {
        audio.play();
      } else {
        audio.pause();
      }
    }

    btn.addEventListener("click", togglePlay);
    if (miniBtn) miniBtn.addEventListener("click", togglePlay);

    audio.addEventListener("play", function () {
      markInteracted();
      syncUI();
    });
    audio.addEventListener("pause", syncUI);

    audio.addEventListener("loadedmetadata", function () {
      const d = fmt(audio.duration);
      if (durationEl) durationEl.textContent = d;
      if (miniDuration) miniDuration.textContent = d;
    });

    audio.addEventListener("timeupdate", function () {
      const t = fmt(audio.currentTime);
      if (currentEl) currentEl.textContent = t;
      if (miniCurrent) miniCurrent.textContent = t;
      if (audio.duration) {
        const pct = (audio.currentTime / audio.duration * 100) + "%";
        if (fill) fill.style.width = pct;
        if (miniFill) miniFill.style.width = pct;
      }
    });

    audio.addEventListener("ended", function () {
      audio.currentTime = 0;
      syncUI();
    });

    // Seeking — works on both inline and mini tracks, drives the same audio element.
    function seek(clientX, trackEl) {
      if (!audio.duration) return;
      const rect = trackEl.getBoundingClientRect();
      const x = Math.max(0, Math.min(clientX - rect.left, rect.width));
      audio.currentTime = (x / rect.width) * audio.duration;
      markInteracted();
    }

    let dragging = null; // currently-dragged track element (or null)

    function bindTrack(trackEl) {
      if (!trackEl) return;
      trackEl.addEventListener("mousedown", function (e) {
        dragging = trackEl;
        seek(e.clientX, trackEl);
      });
      trackEl.addEventListener("touchstart", function (e) {
        seek(e.touches[0].clientX, trackEl);
      }, { passive: true });
      trackEl.addEventListener("touchmove", function (e) {
        seek(e.touches[0].clientX, trackEl);
      }, { passive: true });
      trackEl.addEventListener("keydown", function (e) {
        if (!audio.duration) return;
        if (e.key === "ArrowRight") {
          audio.currentTime = Math.min(audio.duration, audio.currentTime + 5);
          markInteracted();
        } else if (e.key === "ArrowLeft") {
          audio.currentTime = Math.max(0, audio.currentTime - 5);
          markInteracted();
        }
      });
    }
    bindTrack(track);
    bindTrack(miniTrack);

    document.addEventListener("mousemove", function (e) {
      if (dragging) seek(e.clientX, dragging);
    });
    document.addEventListener("mouseup", function () {
      dragging = null;
    });

    // Speed cycle (inline only — mini intentionally omits it to keep the bar slim)
    if (speedBtn) {
      speedBtn.addEventListener("click", function () {
        speedIdx = (speedIdx + 1) % speeds.length;
        audio.playbackRate = speeds[speedIdx];
        speedBtn.textContent = speeds[speedIdx] + "x";
        markInteracted();
      });
    }

    // Mini-only: dismiss + jump back to inline player
    if (miniClose) {
      miniClose.addEventListener("click", function () {
        dismissed = true;
        updateMiniVisibility();
      });
    }
    if (miniJump) {
      miniJump.addEventListener("click", function () {
        if (wrap) wrap.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    }

    // Track inline visibility relative to the (live) header height. We use a
    // scroll/resize listener rather than IntersectionObserver because the header
    // height changes on scroll-collapse, and rootMargin is frozen at observer
    // construction. A rAF-throttled bounding-rect read is plenty fast for one element.
    if (mini && wrap) {
      function getHeaderOffset() {
        const v = getComputedStyle(document.documentElement).getPropertyValue("--header-height").trim();
        const n = parseInt(v, 10);
        return isFinite(n) ? n : 64;
      }

      let rafPending = false;
      function checkInline() {
        rafPending = false;
        const rect = wrap.getBoundingClientRect();
        // Inline is "visible enough" while its bottom edge is below the header's bottom edge.
        const newVisible = rect.bottom > getHeaderOffset();
        if (newVisible !== inlineVisible) {
          inlineVisible = newVisible;
          updateMiniVisibility();
        }
      }
      function onScrollOrResize() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(checkInline);
      }
      window.addEventListener("scroll", onScrollOrResize, { passive: true });
      window.addEventListener("resize", onScrollOrResize, { passive: true });
      checkInline();
    }
  })();
</script>
