---
interface Props {
  num: number;
  label?: string;
}

const { num, label } = Astro.props;

const res = await fetch(`https://xkcd.com/${num}/info.0.json`);
if (!res.ok) {
  throw new Error(`Failed to fetch XKCD #${num}: ${res.status}`);
}
const comic = await res.json();
const { title, alt, img } = comic;
const href = `https://xkcd.com/${num}/`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="xkcd-card not-prose group"
  aria-label={`XKCD #${num}: ${title}`}
>
  <!-- Grid texture -->
  <span class="xk-grid" aria-hidden="true"></span>
  <!-- Ambient glow -->
  <span class="xk-glow" aria-hidden="true"></span>
  <!-- Corner marks -->
  <span class="xk-corner xk-tl" aria-hidden="true"></span>
  <span class="xk-corner xk-tr" aria-hidden="true"></span>
  <span class="xk-corner xk-bl" aria-hidden="true"></span>
  <span class="xk-corner xk-br" aria-hidden="true"></span>

  <div class="xk-inner">
    {label && <p class="xk-label">{label}</p>}

    <div class="xk-header">
      <svg class="xk-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <line x1="3" y1="9" x2="21" y2="9" />
        <line x1="9" y1="3" x2="9" y2="9" />
      </svg>
      <span class="xk-title">{title}</span>
      <span class="xk-badge">#{num}</span>
    </div>

    <div class="xk-img-wrap">
      <img
        src={img}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="xk-img"
      />
    </div>

    <span class="xk-rule" aria-hidden="true"></span>

    <div class="xk-footer">
      <p class="xk-alt">{alt}</p>
      <span class="xk-cta">
        View on xkcd.com
        <svg class="xk-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4"></path>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .xkcd-card {
    display: block;
    position: relative;
    margin: 3rem auto;
    border-radius: 0.875rem;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    background: color-mix(in srgb, var(--background) 88%, #000);
    overflow: hidden;
    text-decoration: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    padding: 0.25rem;
  }

  .xkcd-card:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow: 0 8px 40px -8px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  /* Subtle grid texture */
  .xk-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--accent) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--accent) 5%, transparent) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* Central radial glow */
  .xk-glow {
    position: absolute;
    width: 75%;
    height: 220%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      color-mix(in srgb, var(--accent) 11%, transparent) 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Corner bracket marks */
  .xk-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: color-mix(in srgb, var(--accent) 42%, transparent);
    border-style: solid;
    z-index: 2;
  }
  .xk-tl { top: 16px; left: 16px; border-width: 1px 0 0 1px; }
  .xk-tr { top: 16px; right: 16px; border-width: 1px 1px 0 0; }
  .xk-bl { bottom: 16px; left: 16px; border-width: 0 0 1px 1px; }
  .xk-br { bottom: 16px; right: 16px; border-width: 0 1px 1px 0; }

  /* Inner content */
  .xk-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 2.5rem 1.75rem;
    gap: 0.875rem;
  }

  /* Optional label */
  .xk-label {
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 60%, transparent);
    margin: 0 0 -0.25rem;
  }

  /* Header: icon + title + badge */
  .xk-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .xk-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--foreground);
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .xkcd-card:hover .xk-icon {
    opacity: 1;
    color: var(--accent);
  }

  .xk-title {
    font-family: var(--font-cartograph, monospace);
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  .xk-badge {
    font-family: var(--font-cartograph, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    opacity: 0.75;
  }

  /* Comic image */
  .xk-img-wrap {
    margin: 0.5rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #fff;
    padding: 0.75rem;
    max-width: 100%;
  }

  .xk-img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  /* Divider rule */
  .xk-rule {
    display: block;
    width: 3rem;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 50%, transparent);
    margin: 0.25rem auto;
  }

  /* Footer */
  .xk-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .xk-alt {
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.72rem;
    font-style: italic;
    line-height: 1.55;
    color: var(--foreground);
    opacity: 0.55;
    max-width: 38rem;
    margin: 0;
  }

  .xk-cta {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 50%, transparent);
    transition: color 0.2s;
  }

  .xkcd-card:hover .xk-cta {
    color: var(--accent);
  }

  .xk-arrow {
    width: 0.75rem;
    height: 0.75rem;
    transition: transform 0.2s;
  }

  .xkcd-card:hover .xk-arrow {
    transform: translateX(3px);
  }
</style>
