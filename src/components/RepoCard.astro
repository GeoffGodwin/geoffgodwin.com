---
interface Props {
  owner: string;
  repo: string;
  description: string;
  language?: string;
  languageColor?: string;
  /** Optional image or SVG URL shown at the left edge of the card */
  img?: string;
}

const {
  owner,
  repo,
  description,
  language = "Shell",
  languageColor = "#89e051",
  img,
} = Astro.props;

const href = `https://github.com/${owner}/${repo}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["repo-card not-prose group", { "has-img": !!img }]}
  aria-label={`View ${owner}/${repo} on GitHub`}
>
  {img && (
    <div class="repo-img-col">
      <img src={img} alt="" class="repo-img" loading="lazy" />
    </div>
  )}
  <div class="repo-card-inner">
    <!-- Header row -->
    <div class="repo-card-header">
      <svg
        class="repo-icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="currentColor"
      >
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
        ></path>
      </svg>
      <span class="repo-name">{owner}<span class="repo-sep">/</span>{repo}</span>
      <span class="repo-badge">Public</span>
    </div>

    <!-- Description -->
    <p class="repo-desc">{description}</p>

    <!-- Footer row -->
    <div class="repo-footer">
      <span class="repo-lang">
        <span class="repo-lang-dot" style={`background:${languageColor}`}
        ></span>
        {language}
      </span>
      <span class="repo-cta">
        View on GitHub
        <svg
          class="repo-arrow"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M3 8h10M9 4l4 4-4 4"></path>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .repo-card {
    display: block;
    margin: 2rem 0;
    border-radius: 0.875rem;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
    background: color-mix(in srgb, var(--accent) 4%, var(--background));
    text-decoration: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s,
      transform 0.15s;
    overflow: hidden;
  }

  .repo-card.has-img {
    display: flex;
    flex-direction: row;
  }

  .repo-card:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow: 0 4px 24px -4px color-mix(in srgb, var(--accent) 20%, transparent);
    transform: translateY(-1px);
  }

  /* Image column */
  .repo-img-col {
    flex-shrink: 0;
    width: 7.5rem;
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding: 0;
  }

  .repo-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.75rem 1rem;
  }

  .repo-card-inner {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    min-width: 0;
    flex: 1;
  }

  /* Stack vertically on very narrow viewports */
  @media (max-width: 28rem) {
    .repo-card.has-img {
      flex-direction: column;
    }

    .repo-img-col {
      width: 100%;
      height: 4rem;
    }
  }

  .repo-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .repo-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--foreground);
    opacity: 0.6;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .repo-card:hover .repo-icon {
    opacity: 1;
    color: var(--accent);
  }

  .repo-name {
    font-family: var(--font-cartograph);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  .repo-sep {
    opacity: 0.5;
    margin: 0 0.05em;
  }

  .repo-badge {
    margin-left: auto;
    font-family: var(--font-cartograph);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    opacity: 0.75;
  }

  .repo-desc {
    font-size: 0.9rem;
    color: var(--foreground);
    opacity: 0.75;
    margin: 0;
    line-height: 1.55;
  }

  .repo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.25rem;
  }

  .repo-lang {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-cartograph);
    font-size: 0.75rem;
    color: var(--foreground);
    opacity: 0.55;
  }

  .repo-lang-dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .repo-cta {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-cartograph);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    opacity: 0.7;
    transition: opacity 0.2s;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .repo-card:hover .repo-cta {
    opacity: 1;
  }

  .repo-arrow {
    width: 0.85rem;
    height: 0.85rem;
    transition: transform 0.2s;
  }

  .repo-card:hover .repo-arrow {
    transform: translateX(3px);
  }
</style>
