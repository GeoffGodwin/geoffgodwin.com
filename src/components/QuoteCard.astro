---
interface Props {
  quote: string;
  emphasis?: string;
  attribution: string;
  source?: string;
  sourceUrl?: string;
  label?: string;
}

const {
  quote,
  emphasis,
  attribution,
  source,
  sourceUrl,
  label,
} = Astro.props;

const parts = emphasis ? quote.split(emphasis) : [quote];
---

<div class="pull-quote not-prose" aria-label="Pull quote">
  <!-- Grid texture -->
  <span class="pq-grid" aria-hidden="true"></span>
  <!-- Ambient glow -->
  <span class="pq-glow" aria-hidden="true"></span>
  <!-- Corner marks -->
  <span class="pq-corner pq-tl" aria-hidden="true"></span>
  <span class="pq-corner pq-tr" aria-hidden="true"></span>
  <span class="pq-corner pq-bl" aria-hidden="true"></span>
  <span class="pq-corner pq-br" aria-hidden="true"></span>

  <div class="pq-inner">
    {label && <p class="pq-label">{label}</p>}

    <span class="pq-mark" aria-hidden="true">&ldquo;</span>

    <blockquote class="pq-text">
      {emphasis ? (
        <>
          {parts[0]}<em class="pq-emphasis">{emphasis}</em>{parts[1]}
        </>
      ) : (
        quote
      )}
    </blockquote>

    <span class="pq-rule" aria-hidden="true"></span>

    <footer class="pq-footer">
      <span class="pq-attribution">{attribution}</span>
      {source && sourceUrl && (
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="pq-source">
          {source}
          <svg class="pq-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4"></path>
          </svg>
        </a>
      )}
      {source && !sourceUrl && (
        <span class="pq-source-plain">{source}</span>
      )}
    </footer>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&display=swap');

  .pull-quote {
    position: relative;
    margin: 3rem auto;
    border-radius: 0.875rem;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    background: color-mix(in srgb, var(--background) 88%, #000);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    padding: 0.25rem;
  }

  .pull-quote:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow: 0 8px 40px -8px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  /* Subtle grid texture */
  .pq-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--accent) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--accent) 5%, transparent) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* Central radial glow */
  .pq-glow {
    position: absolute;
    width: 75%;
    height: 220%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      color-mix(in srgb, var(--accent) 11%, transparent) 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Corner bracket marks */
  .pq-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: color-mix(in srgb, var(--accent) 42%, transparent);
    border-style: solid;
    z-index: 2;
  }
  .pq-tl { top: 16px; left: 16px; border-width: 1px 0 0 1px; }
  .pq-tr { top: 16px; right: 16px; border-width: 1px 1px 0 0; }
  .pq-bl { bottom: 16px; left: 16px; border-width: 0 0 1px 1px; }
  .pq-br { bottom: 16px; right: 16px; border-width: 0 1px 1px 0; }

  /* Inner content: centered layout with generous vertical padding */
  .pq-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 3.5rem 2.5rem;
    gap: 0.875rem;
  }

  /* Optional post label */
  .pq-label {
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 60%, transparent);
    margin: 0 0 -0.25rem;
  }

  /* Large decorative opening quotation mark */
  .pq-mark {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 6rem;
    line-height: 0.5;
    color: color-mix(in srgb, var(--accent) 28%, transparent);
    display: block;
    user-select: none;
    margin-bottom: 0.75rem;
  }

  /* The quote text in Playfair italic */
  .pq-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.32rem, 3vw, 1.68rem);
    line-height: 1.6;
    color: var(--foreground);
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    max-width: 38rem;
  }

  /* Highlighted emphasis phrase: upright bold in accent color */
  .pq-emphasis {
    font-style: normal;
    font-weight: 700;
    color: var(--accent);
  }

  /* Short accent rule divider */
  .pq-rule {
    display: block;
    width: 3rem;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 50%, transparent);
    margin: 0.5rem auto 0.25rem;
  }

  /* Footer: centered attribution + optional source link stacked */
  .pq-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .pq-attribution {
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 72%, transparent);
  }

  .pq-source {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 50%, transparent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .pull-quote:hover .pq-source {
    color: var(--accent);
  }

  .pq-source-plain {
    font-family: 'IBM Plex Mono', var(--font-cartograph, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--foreground) 30%, transparent);
  }

  .pq-arrow {
    width: 0.75rem;
    height: 0.75rem;
    transition: transform 0.2s;
  }

  .pull-quote:hover .pq-arrow {
    transform: translateX(3px);
  }
</style>