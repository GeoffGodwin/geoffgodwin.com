---
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  label?: string;
}

const { src, alt, caption, label } = Astro.props;
const imgSrc = typeof src === "string" ? src : src.src;
---

<figure class="svg-card not-prose" aria-label={label ?? alt}>
  <!-- Grid texture -->
  <span class="sv-grid" aria-hidden="true"></span>
  <!-- Ambient glow -->
  <span class="sv-glow" aria-hidden="true"></span>
  <!-- Corner marks -->
  <span class="sv-corner sv-tl" aria-hidden="true"></span>
  <span class="sv-corner sv-tr" aria-hidden="true"></span>
  <span class="sv-corner sv-bl" aria-hidden="true"></span>
  <span class="sv-corner sv-br" aria-hidden="true"></span>

  <div class="sv-inner">
    {label && <p class="sv-label">{label}</p>}

    <div class="sv-img-wrap">
      <img
        src={imgSrc}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="sv-img"
      />
    </div>

    {
      caption && (
        <>
          <span class="sv-rule" aria-hidden="true" />
          <figcaption class="sv-caption">{caption}</figcaption>
        </>
      )
    }
  </div>
</figure>

<style>
  .svg-card {
    display: block;
    position: relative;
    margin: 3rem auto;
    border-radius: 0.875rem;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    /* Dark background so SVG light-on-dark text stays legible in all themes */
    background: #1c1c1a;
    overflow: hidden;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    padding: 0.25rem;
  }

  .svg-card:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow: 0 8px 40px -8px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  /* Subtle grid texture */
  .sv-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--accent) 5%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--accent) 5%, transparent) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* Central radial glow */
  .sv-glow {
    position: absolute;
    width: 75%;
    height: 220%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent) 11%, transparent) 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Corner bracket marks */
  .sv-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: color-mix(in srgb, var(--accent) 42%, transparent);
    border-style: solid;
    z-index: 2;
  }
  .sv-tl {
    top: 16px;
    left: 16px;
    border-width: 1px 0 0 1px;
  }
  .sv-tr {
    top: 16px;
    right: 16px;
    border-width: 1px 1px 0 0;
  }
  .sv-bl {
    bottom: 16px;
    left: 16px;
    border-width: 0 0 1px 1px;
  }
  .sv-br {
    bottom: 16px;
    right: 16px;
    border-width: 0 1px 1px 0;
  }

  /* Inner content */
  .sv-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.75rem 2rem 1.5rem;
    gap: 0.875rem;
  }

  /* Optional label */
  .sv-label {
    font-family: "IBM Plex Mono", var(--font-cartograph, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 60%, transparent);
    margin: 0 0 -0.25rem;
    align-self: flex-start;
  }

  /* Image wrapper */
  .sv-img-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .sv-img {
    width: 100%;
    max-width: 680px;
    height: auto;
    display: block;
    border-radius: 0.25rem;
  }

  /* Divider rule */
  .sv-rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 35%, transparent);
    align-self: center;
    margin: 0.125rem 0;
  }

  /* Caption */
  .sv-caption {
    font-family: "IBM Plex Mono", var(--font-cartograph, monospace);
    font-size: 0.75rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--foreground) 55%, transparent);
    text-align: center;
    max-width: 52ch;
    margin: 0;
  }

  @media (max-width: 640px) {
    .sv-inner {
      padding: 1.25rem 1.25rem 1.25rem;
    }
  }
</style>
